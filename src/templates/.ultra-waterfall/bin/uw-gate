#!/bin/sh
# uw-gate — ultra-waterfall 강제 레이어 보조 엔진 (POSIX sh, 도구비종속)
#
# 정직한 위상: 로컬에서 도는 이 스크립트는 "강제(enforcement)"가 아니라
#   tamper-evidence + 마찰 + 부기(bookkeeping)다. 자율 에이전트는
#   `--no-verify`, `core.hooksPath` 재지정, plumbing/merge 커밋, settings.json
#   자기편집으로 이 모든 로컬 검사를 우회할 수 있다(설계 §0 실측).
# 진짜 하드 강제는 에이전트가 통제하지 못하는 merge 시점 CI(check-gates.sh)+
#   branch protection + least-priv 토큰 + 인간 review 뿐이다.
# 따라서 이 CLI의 비-0 종료는 "막았다"가 아니라 "위반을 가시화했다"로 읽는다.
#
# 사용:
#   uw-gate charter-scope (--staged | --range <base>...<head>) [--charter <path>]
#   uw-gate verify-run <ac-id> --log <path> -- <cmd...>
#   uw-gate halt "<reason>"        # .ultra-waterfall/HALT 세팅(마찰)
#   uw-gate halt-check             # HALT 활성이면 비-0
#   uw-gate doctor [--issue <N>]   # trust-root(branch protection/required check/토큰) 검증, 미충족 시 LOUD FAIL
#   uw-gate install-hooks          # hooks/ → core.hooksPath 배선(증거용)
set -eu

ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "uw-gate: not a git repo" >&2; exit 3; }
UW="$ROOT/.ultra-waterfall"

# 강제 정의 자체(에이전트가 자기 목줄을 늘리지 못하게) — 항상 보호.
# task 산출물(loop-state task-*.json, mydocs/working|report)은 보호 대상 아님.
PROTECTED='
.ultra-waterfall/bin/*
.ultra-waterfall/gate/*
.ultra-waterfall/hooks/*
.github/workflows/uw-gate.yml
.github/CODEOWNERS
.claude/settings.json
'

die() { echo "uw-gate: $*" >&2; exit 1; }

# charter 경로 해소: --charter 인자 > 활성 loop-state(charter 필드) > 추정
resolve_charter() {
  if [ -n "${CHARTER:-}" ]; then echo "$CHARTER"; return; fi
  ls "$UW"/task-*.json >/dev/null 2>&1 || return 1
  ls -t "$UW"/task-*.json 2>/dev/null | head -1 | while read -r f; do
    sed -n 's/.*"charter"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$f" | head -1
  done
}

# charter.md 안의 scope-fence 블록에서 allow/deny glob 추출
# 형식:  <!-- uw:scope-fence:begin --> ... (행:  allow <glob> | deny <glob>) ... <!-- uw:scope-fence:end -->
load_fence() {
  fence_src=$1
  [ -f "$fence_src" ] || die "charter/fence not found: $fence_src"
  awk '/uw:scope-fence:begin/{f=1;next} /uw:scope-fence:end/{f=0} f' "$fence_src"
}

# case 글롭 매칭(POSIX): **를 *로 정규화. case의 *는 /도 가로지름.
match_glob() { # $1=path $2=glob
  p=$1; g=$2
  g=$(printf '%s' "$g" | sed 's/\*\*/\*/g')
  case "$p" in $g) return 0;; esac
  return 1
}

changed_paths() {
  case ${1:-} in
    --staged) git -C "$ROOT" diff --cached --name-only ;;
    --range)  git -C "$ROOT" diff --name-only "$2" ;;
    *) die "changed_paths: --staged|--range required" ;;
  esac
}

cmd_charter_scope() {
  mode=${1:-}; rng=${2:-}
  ch=$(resolve_charter) || die "active charter not found (use --charter)"
  [ -f "$ch" ] || die "charter file missing: $ch"
  fence=$(load_fence "$ch")
  allow=$(printf '%s\n' "$fence" | awk '$1=="allow"{print $2}')
  deny=$(printf '%s\n' "$fence" | awk '$1=="deny"{print $2}')

  if [ "$mode" = "--range" ]; then paths=$(changed_paths --range "$rng"); else paths=$(changed_paths --staged); fi
  [ -n "$paths" ] || { echo "uw-gate charter-scope: 변경 경로 없음 (OK)"; return 0; }

  # noglob 범위 한정: fence/PROTECTED 글롭이 unquoted for-loop에서 cwd로 pathname-expand되는 것 차단.
  # (전역 set -f는 resolve_charter의 `ls` 등을 깨므로 매칭 루프에만 적용.)
  set -f
  viol=0
  for p in $paths; do
    # 1) 보호된 강제정의 경로
    hit=0
    for g in $PROTECTED; do if match_glob "$p" "$g"; then hit=1; break; fi; done
    if [ "$hit" = 1 ]; then echo "VIOLATION(protected): $p — 강제 정의 파일은 LOOP 중 수정 금지(charter급 에스컬레이션)"; viol=1; continue; fi
    # 2) 명시 deny
    hit=0
    for g in $deny; do if match_glob "$p" "$g"; then hit=1; break; fi; done
    if [ "$hit" = 1 ]; then echo "VIOLATION(deny): $p — charter 제외(off-charter)"; viol=1; continue; fi
    # 3) allow 목록이 있으면 그 안에 들어야
    if [ -n "$allow" ]; then
      hit=0
      for g in $allow; do if match_glob "$p" "$g"; then hit=1; break; fi; done
      if [ "$hit" = 0 ]; then echo "VIOLATION(out-of-scope): $p — charter 범위 밖"; viol=1; continue; fi
    fi
  done
  set +f
  if [ "$viol" = 1 ]; then
    echo "uw-gate charter-scope: off-charter 변경 감지. 약화/우회 말고 charter급 에스컬레이션." >&2
    return 1
  fi
  echo "uw-gate charter-scope: 전 변경 경로가 charter scope 내 (OK)"
}

cmd_verify_run() {
  ac=$1; shift
  log=""
  [ "${1:-}" = "--log" ] && { log=$2; shift 2; }
  [ "${1:-}" = "--" ] && shift
  [ -n "$log" ] || die "verify-run: --log <path> 필요"
  mkdir -p "$(dirname "$log")"
  # 기계판독 envelope(자유텍스트 자가인용 금지). harness가 argv/exit 기록.
  ts=$(git -C "$ROOT" log -1 --format=%cI 2>/dev/null || echo "unknown")
  {
    echo "## uw-verify-envelope ac=$ac"
    printf 'argv:'; for a in "$@"; do printf ' %s' "$a"; done; echo
    echo "commit-ts: $ts"
    echo "---- output ----"
  } >>"$log"
  set +e
  "$@" >>"$log" 2>&1
  rc=$?
  set -e
  echo "exit: $rc" >>"$log"
  echo "uw-gate verify-run[$ac]: exit=$rc -> $log"
  return $rc
}

cmd_halt() {
  reason=${1:-"unspecified"}
  mkdir -p "$UW"
  printf '%s\n' "$reason" >"$UW/HALT"
  echo "uw-gate halt: .ultra-waterfall/HALT 세팅(마찰). 진짜 정지는 needs-human 라벨 + CI. 클리어는 외부 주체만." >&2
}

cmd_halt_check() {
  if [ -f "$UW/HALT" ]; then
    echo "HALT active: $(cat "$UW/HALT")" >&2
    echo "  (로컬 sentinel은 마찰일 뿐 — 에이전트가 지울 수 있음. 진짜 게이트=needs-human 라벨/CI.)" >&2
    return 1
  fi
  return 0
}

cmd_doctor() {
  issue=""
  [ "${1:-}" = "--issue" ] && issue=$2
  fail=0
  echo "uw-gate doctor: trust-root(외부 강제) 검증 — 미충족이면 LOUD FAIL(비강제를 강제로 믿는 상태 차단)"
  if ! command -v gh >/dev/null 2>&1; then
    echo "FAIL: gh CLI 없음 → branch protection/required check/토큰 scope 검증 불가. 강제 floor 미확인." >&2
    return 1
  fi
  slug=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null) || { echo "FAIL: gh repo 조회 불가(원격/인증)." >&2; return 1; }
  base=$(gh repo view --json defaultBranchRef -q .defaultBranchRef.name 2>/dev/null || echo main)
  # 1) base branch protection + required status check
  if gh api "repos/$slug/branches/$base/protection" >/tmp/uwprot.$$ 2>/dev/null; then
    if grep -q 'uw-gate' /tmp/uwprot.$$ 2>/dev/null; then echo "OK: $base 보호 + uw-gate required check"; else echo "FAIL: $base 보호는 있으나 uw-gate가 required check 아님" >&2; fail=1; fi
  else
    echo "FAIL: $base branch protection 미설정 → merge 하드 게이트 없음(전체가 honor-system으로 붕괴)." >&2; fail=1
  fi
  rm -f /tmp/uwprot.$$
  # 2) 토큰 권한(에이전트 토큰이 merge/admin 보유하면 G4 우회) — 휴리스틱
  if gh auth status 2>&1 | grep -qiE 'admin|repo\b'; then
    echo "WARN: 현재 토큰이 광범위 scope일 수 있음. 에이전트 실행 토큰은 merge·label-remove·base push·workflow write를 박탈해야 G4 성립." >&2
  fi
  if [ "$fail" = 1 ]; then
    echo "uw-gate doctor: 강제 floor 미충족 → loop-state.enforcement.doctorVerified=false. 'active'로 기록 금지." >&2
    return 1
  fi
  echo "uw-gate doctor: 강제 floor 확인됨(branch protection + required uw-gate check)."
}

cmd_install_hooks() {
  src="$UW/hooks"
  [ -d "$src" ] || die "hooks dir 없음: $src"
  git -C "$ROOT" config core.hooksPath ".ultra-waterfall/hooks"
  chmod +x "$src"/* 2>/dev/null || true
  echo "uw-gate install-hooks: core.hooksPath=.ultra-waterfall/hooks (tamper-evidence 배선)."
  echo "  주의: fresh clone은 이 설정이 UNSET(fail-OPEN)이다. CI가 유일한 신뢰 floor." >&2
}

sub=${1:-}; [ $# -gt 0 ] && shift || true
case "$sub" in
  charter-scope) cmd_charter_scope "$@" ;;
  verify-run)    cmd_verify_run "$@" ;;
  halt)          cmd_halt "$@" ;;
  halt-check)    cmd_halt_check "$@" ;;
  doctor)        cmd_doctor "$@" ;;
  install-hooks) cmd_install_hooks "$@" ;;
  *) echo "uw-gate: unknown subcommand '${sub:-}' (charter-scope|verify-run|halt|halt-check|doctor|install-hooks)" >&2; exit 2 ;;
esac

#!/usr/bin/env python3
"""Fresh cross-model verifier harness for Ultra-Waterfall."""

from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import json
import os
import pathlib
import re
import shutil
import subprocess
import sys
import tarfile
import tempfile
import uuid
from typing import Any


SCHEMA_VERSION = "0.1.0"
STATE_SCHEMA_VERSION = "0.4.0"
PROVIDERS = {"codex", "claude"}
OPPOSITE = {"codex": "claude", "claude": "codex"}
CODEX_EFFORTS = {"none", "minimal", "low", "medium", "high", "xhigh", "max", "ultra"}
CLAUDE_EFFORTS = {"low", "medium", "high", "xhigh", "max"}
SAFE_ID = re.compile(r"^[A-Za-z][A-Za-z0-9_-]*$")
COMMIT_ID = re.compile(r"^[0-9a-f]{40,64}$")


class VerifierError(RuntimeError):
    pass


def fail(message: str) -> None:
    raise VerifierError(message)


def utc_now() -> str:
    return dt.datetime.now(dt.timezone.utc).isoformat().replace("+00:00", "Z")


def sha256_bytes(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def sha256_file(path: pathlib.Path) -> str:
    return sha256_bytes(path.read_bytes())


def json_bytes(value: Any) -> bytes:
    return (json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(",", ":")) + "\n").encode()


def load_json(path: pathlib.Path) -> dict[str, Any]:
    try:
        value = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError) as exc:
        fail(f"invalid JSON {path}: {exc}")
    if not isinstance(value, dict):
        fail(f"JSON object required: {path}")
    return value


def exact_keys(value: dict[str, Any], allowed: set[str], required: set[str], label: str) -> None:
    missing = required - value.keys()
    extra = value.keys() - allowed
    if missing:
        fail(f"{label}: missing keys: {', '.join(sorted(missing))}")
    if extra:
        fail(f"{label}: unsupported keys: {', '.join(sorted(extra))}")


def validate_nonempty(value: Any, label: str) -> str:
    if not isinstance(value, str) or not value.strip():
        fail(f"{label}: non-empty string required")
    return value


def validate_config(config: dict[str, Any]) -> None:
    exact_keys(
        config,
        {"$schema", "schemaVersion", "mode", "providers", "timeoutSeconds"},
        {"schemaVersion", "mode", "providers", "timeoutSeconds"},
        "config",
    )
    if config["schemaVersion"] != SCHEMA_VERSION:
        fail(f"config: schemaVersion must be {SCHEMA_VERSION}")
    if config["mode"] != "opposite-provider":
        fail("config: mode must be opposite-provider")
    timeout = config["timeoutSeconds"]
    if isinstance(timeout, bool) or not isinstance(timeout, int) or not 30 <= timeout <= 7200:
        fail("config: timeoutSeconds must be an integer in 30..7200")
    providers = config["providers"]
    if not isinstance(providers, dict) or set(providers) != PROVIDERS:
        fail("config: providers must contain exactly codex and claude")
    for name in ("codex", "claude"):
        value = providers[name]
        if not isinstance(value, dict):
            fail(f"config.providers.{name}: object required")
        allowed = {"binary", "model", "effort"}
        if name == "claude":
            allowed.add("maxBudgetUsd")
        exact_keys(value, allowed, {"binary", "model", "effort"}, f"config.providers.{name}")
        binary = validate_nonempty(value["binary"], f"config.providers.{name}.binary")
        if re.search(r"\s", binary):
            fail(f"config.providers.{name}.binary: arguments are not allowed")
        validate_nonempty(value["model"], f"config.providers.{name}.model")
        efforts = CODEX_EFFORTS if name == "codex" else CLAUDE_EFFORTS
        if value["effort"] not in efforts:
            fail(f"config.providers.{name}.effort: unsupported value {value['effort']!r}")
        budget = value.get("maxBudgetUsd")
        if budget is not None and (isinstance(budget, bool) or not isinstance(budget, (int, float)) or budget <= 0):
            fail("config.providers.claude.maxBudgetUsd: positive number or null required")


def validate_decision(value: dict[str, Any]) -> None:
    exact_keys(value, {"verdict", "drift", "summary", "findings", "probes"}, {"verdict", "drift", "summary", "findings", "probes"}, "decision")
    if value["verdict"] not in {"OK", "MISS"} or value["drift"] not in {"OK", "MISS"}:
        fail("decision: verdict and drift must be OK or MISS")
    validate_nonempty(value["summary"], "decision.summary")
    if not isinstance(value["findings"], list):
        fail("decision.findings: array required")
    for index, finding in enumerate(value["findings"]):
        if not isinstance(finding, dict):
            fail(f"decision.findings[{index}]: object required")
        exact_keys(finding, {"severity", "title", "evidence"}, {"severity", "title", "evidence"}, f"decision.findings[{index}]")
        if finding["severity"] not in {"critical", "high", "medium", "low"}:
            fail(f"decision.findings[{index}].severity: invalid")
        validate_nonempty(finding["title"], f"decision.findings[{index}].title")
        validate_nonempty(finding["evidence"], f"decision.findings[{index}].evidence")
    if not isinstance(value["probes"], list) or not value["probes"]:
        fail("decision.probes: at least one probe required")
    ids: set[str] = set()
    for index, probe in enumerate(value["probes"]):
        if not isinstance(probe, dict):
            fail(f"decision.probes[{index}]: object required")
        exact_keys(probe, {"id", "purpose", "result"}, {"id", "purpose", "result"}, f"decision.probes[{index}]")
        probe_id = probe["id"]
        if not isinstance(probe_id, str) or not SAFE_ID.fullmatch(probe_id) or probe_id in ids:
            fail(f"decision.probes[{index}].id: safe unique id required")
        ids.add(probe_id)
        validate_nonempty(probe["purpose"], f"decision.probes[{index}].purpose")
        if probe["result"] not in {"no-violation", "violation", "inconclusive"}:
            fail(f"decision.probes[{index}].result: invalid")
    if value["verdict"] == "OK":
        if value["drift"] != "OK" or value["findings"] or any(p["result"] != "no-violation" for p in value["probes"]):
            fail("decision: OK contradicts drift, findings, or probe results")


def repo_root() -> pathlib.Path:
    result = subprocess.run(["git", "rev-parse", "--show-toplevel"], text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=False)
    if result.returncode != 0:
        fail("run inside a git repository")
    return pathlib.Path(result.stdout.strip()).resolve()


def git(root: pathlib.Path, *args: str, text: bool = True) -> str | bytes:
    result = subprocess.run(["git", "-C", str(root), *args], stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=text, check=False)
    if result.returncode != 0:
        stderr = result.stderr.strip() if text else result.stderr.decode(errors="replace").strip()
        fail(f"git {' '.join(args)}: {stderr}")
    return result.stdout


def safe_relative(path: str, label: str) -> pathlib.PurePosixPath:
    pure = pathlib.PurePosixPath(path)
    if pure.is_absolute() or ".." in pure.parts or not pure.parts:
        fail(f"{label}: safe repository-relative path required")
    return pure


def config_path(root: pathlib.Path, override: str | None) -> pathlib.Path:
    path = pathlib.Path(override) if override else root / ".ultra-waterfall/verifier/config.json"
    if not path.is_absolute():
        path = root / path
    return path.resolve()


def clean_env() -> dict[str, str]:
    allowed = {"HOME", "PATH", "TMPDIR", "LANG", "LC_ALL", "LC_CTYPE", "TERM", "USER", "LOGNAME"}
    return {key: value for key, value in os.environ.items() if key in allowed}


def resolve_binary(binary: str) -> str:
    resolved = shutil.which(binary)
    if not resolved:
        fail(f"verifier binary not found: {binary}")
    return resolved


def run_checked(argv: list[str], *, cwd: pathlib.Path, timeout: int, stdin: str | None = None) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(argv, cwd=cwd, env=clean_env(), input=stdin, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=timeout, check=False)
    except subprocess.TimeoutExpired as exc:
        fail(f"command timed out after {timeout}s: {argv[0]}")


def provider_status(config: dict[str, Any], implementer: str) -> dict[str, Any]:
    if implementer not in PROVIDERS:
        fail("implementer must be codex or claude")
    provider = OPPOSITE[implementer]
    settings = config["providers"][provider]
    binary = resolve_binary(settings["binary"])
    version = run_checked([binary, "--version"], cwd=pathlib.Path.cwd(), timeout=20)
    if version.returncode != 0 or not (version.stdout.strip() or version.stderr.strip()):
        fail(f"{provider} --version failed")
    auth_argv = [binary, "login", "status"] if provider == "codex" else [binary, "auth", "status"]
    auth = run_checked(auth_argv, cwd=pathlib.Path.cwd(), timeout=20)
    if auth.returncode != 0:
        fail(f"{provider} authentication is not ready")
    return {
        "mode": "opposite-provider",
        "implementerProvider": implementer,
        "provider": provider,
        "binary": settings["binary"],
        "resolvedBinary": binary,
        "model": settings["model"],
        "effort": settings["effort"],
        "cliVersion": (version.stdout.strip() or version.stderr.strip()).splitlines()[0],
    }


def extract_archive(root: pathlib.Path, candidate: str, target: pathlib.Path) -> None:
    archive = subprocess.run(["git", "-C", str(root), "archive", "--format=tar", candidate], stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=False)
    if archive.returncode != 0:
        fail(f"git archive {candidate}: {archive.stderr.decode(errors='replace').strip()}")
    target.mkdir(parents=True)
    with tarfile.open(fileobj=__import__("io").BytesIO(archive.stdout), mode="r:") as tar:
        for member in tar.getmembers():
            pure = pathlib.PurePosixPath(member.name)
            if pure.is_absolute() or ".." in pure.parts:
                fail(f"unsafe archive member: {member.name}")
            destination = target.joinpath(*pure.parts)
            destination.parent.mkdir(parents=True, exist_ok=True)
            if member.isdir():
                destination.mkdir(exist_ok=True)
            elif member.isfile():
                source = tar.extractfile(member)
                if source is None:
                    fail(f"archive member has no content: {member.name}")
                destination.write_bytes(source.read())
                destination.chmod(member.mode & 0o777)
            elif member.issym():
                link = pathlib.PurePosixPath(member.linkname)
                if link.is_absolute():
                    fail(f"unsafe archive symlink: {member.name} -> {member.linkname}")
                resolved = (destination.parent / member.linkname).resolve(strict=False)
                try:
                    resolved.relative_to(target.resolve())
                except ValueError:
                    fail(f"unsafe archive symlink: {member.name} -> {member.linkname}")
                destination.symlink_to(member.linkname)
            else:
                fail(f"unsupported archive member: {member.name}")


def write_probe_wrapper(path: pathlib.Path) -> None:
    path.write_text("""#!/bin/sh
set -eu
[ "${1:-}" = "--id" ] || { echo "usage: uw-probe --id ID -- command [args...]" >&2; exit 2; }
id=${2:-}
case "$id" in ''|*[!A-Za-z0-9_-]*|[0-9_-]*) echo "unsafe probe id" >&2; exit 2 ;; esac
shift 2
[ "${1:-}" = "--" ] || { echo "missing --" >&2; exit 2; }
shift
[ "$#" -gt 0 ] || { echo "probe command required" >&2; exit 2; }
root=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
work="$root/probe-work/$id"
log="$root/probes/$id.log"
rm -rf "$work"
mkdir -p "$work" "$root/probes"
cp -R "$root/candidate/." "$work/"
set +e
(cd "$work" && "$@") >"$log.stdout" 2>"$log.stderr"
rc=$?
set -e
{
  printf '## uw-cross-model-probe id=%s\\n' "$id"
  printf 'argv:'
  printf ' %s' "$@"
  printf '\\nexit: %s\\n--- stdout ---\\n' "$rc"
  cat "$log.stdout"
  printf '\\n--- stderr ---\\n'
  cat "$log.stderr"
} >"$log"
rm -f "$log.stdout" "$log.stderr"
cat "$log"
exit 0
""")
    path.chmod(0o755)


def load_chain(root: pathlib.Path, head: Any) -> tuple[dict[str, Any] | None, list[dict[str, Any]]]:
    if head is None:
        return None, []
    if not isinstance(head, dict):
        fail("loop-state verifier.chainHead must be object or null")
    exact_keys(head, {"path", "sha256"}, {"path", "sha256"}, "verifier.chainHead")
    ledger: list[dict[str, Any]] = []
    seen: set[str] = set()
    current: dict[str, Any] | None = head
    while current is not None:
        path_text = validate_nonempty(current.get("path"), "chain path")
        expected = validate_nonempty(current.get("sha256"), "chain sha256")
        if path_text in seen or len(seen) >= 128:
            fail("envelope chain cycle or excessive length")
        seen.add(path_text)
        pure = safe_relative(path_text, "chain path")
        path = root.joinpath(*pure.parts)
        if not path.is_file() or sha256_file(path) != expected:
            fail(f"envelope chain hash mismatch: {path_text}")
        envelope = load_json(path)
        decision = envelope.get("decision", {})
        probes = decision.get("probes", []) if isinstance(decision, dict) else []
        ledger.append({
            "candidate": envelope.get("candidate"),
            "status": envelope.get("status"),
            "drift": decision.get("drift") if isinstance(decision, dict) else None,
            "probeResults": [
                {"id": probe.get("id"), "purpose": probe.get("purpose"), "result": probe.get("result")}
                for probe in probes if isinstance(probe, dict)
            ],
            "findingTitles": [finding.get("title") for finding in decision.get("findings", []) if isinstance(finding, dict)] if isinstance(decision, dict) else [],
        })
        previous = envelope.get("previousEnvelope")
        if previous is not None and not isinstance(previous, dict):
            fail(f"invalid previousEnvelope: {path_text}")
        current = previous
    ledger.reverse()
    return head, ledger


def build_bundle(root: pathlib.Path, task: int, phase: str, stage: int | None, candidate: str, state: dict[str, Any], config: dict[str, Any], frozen_log: pathlib.Path, ledger: list[dict[str, Any]], bundle: pathlib.Path) -> str:
    verifier_dir = root / ".ultra-waterfall/verifier"
    extract_archive(root, candidate, bundle / "candidate")
    shutil.copy2(verifier_dir / "prompt.md", bundle / "prompt.md")
    shutil.copy2(verifier_dir / "decision.schema.json", bundle / "decision.schema.json")
    write_probe_wrapper(bundle / "uw-probe")
    charter_rel = str(safe_relative(validate_nonempty(state.get("charter"), "loop-state charter"), "loop-state charter"))
    charter = git(root, "show", f"{candidate}:{charter_rel}", text=False)
    assert isinstance(charter, bytes)
    (bundle / "charter.md").write_bytes(charter)
    parent = str(git(root, "rev-parse", f"{candidate}^", text=True)).strip()
    base = str(git(root, "merge-base", "origin/main", candidate, text=True)).strip()
    stage_diff = str(git(root, "diff", "--binary", parent, candidate, text=True))
    cumulative_diff = str(git(root, "diff", "--binary", base, candidate, text=True))
    (bundle / "stage.diff").write_text(stage_diff)
    (bundle / "cumulative.diff").write_text(cumulative_diff)
    shutil.copy2(frozen_log, bundle / "frozen-verification.log")
    inputs = {
        "schemaVersion": SCHEMA_VERSION,
        "task": task,
        "phase": phase,
        "stage": stage,
        "candidate": candidate,
        "base": base,
        "charter": {"path": "charter.md", "sha256": sha256_bytes(charter)},
        "stageDiff": {"path": "stage.diff", "sha256": sha256_bytes(stage_diff.encode())},
        "cumulativeDiff": {"path": "cumulative.diff", "sha256": sha256_bytes(cumulative_diff.encode())},
        "frozenVerification": {"path": "frozen-verification.log", "sha256": sha256_file(frozen_log)},
        "priorLedger": ledger,
        "constraints": {"freshSession": True, "network": False, "credentials": False},
    }
    (bundle / "input.json").write_bytes(json_bytes(inputs))
    digest = hashlib.sha256()
    for name in ("prompt.md", "decision.schema.json", "charter.md", "stage.diff", "cumulative.diff", "frozen-verification.log", "input.json", "uw-probe"):
        data = (bundle / name).read_bytes()
        digest.update(name.encode() + b"\0" + data + b"\0")
    return digest.hexdigest()


def provider_argv(provider: str, status: dict[str, Any], config: dict[str, Any], bundle: pathlib.Path) -> tuple[list[str], pathlib.Path | None]:
    binary = status["resolvedBinary"]
    model = status["model"]
    effort = status["effort"]
    if provider == "codex":
        decision_path = bundle / "decision.out.json"
        return ([
            binary, "exec", "--ephemeral", "--ignore-user-config", "--ignore-rules",
            "--skip-git-repo-check", "--sandbox", "workspace-write", "--json",
            "-c", "sandbox_workspace_write.network_access=false", "-c", 'web_search="disabled"',
            "-c", "shell_environment_policy.inherit=none", "--output-schema", str(bundle / "decision.schema.json"),
            "--output-last-message", str(decision_path), "--model", model,
            "-c", f'model_reasoning_effort="{effort}"', "-C", str(bundle), "-"
        ], decision_path)
    settings = {
        "sandbox": {
            "enabled": True,
            "failIfUnavailable": True,
            "autoAllowBashIfSandboxed": True,
            "allowUnsandboxedCommands": False,
            "filesystem": {"denyRead": ["~/"], "allowRead": ["."]},
            "network": {"allowedDomains": []},
        },
        "permissions": {
            "allow": ["Bash", "Read", "Glob", "Grep"],
            "deny": ["Agent", "Edit", "Write", "NotebookEdit", "WebFetch", "WebSearch"],
        },
    }
    settings_path = bundle / "claude-settings.json"
    settings_path.write_bytes(json_bytes(settings))
    claude_schema = load_json(bundle / "decision.schema.json")
    claude_schema.pop("$schema", None)
    claude_schema.pop("$id", None)
    schema_inline = json.dumps(claude_schema, separators=(",", ":"))
    argv = [
        binary, "--print", "--no-session-persistence", "--safe-mode", "--strict-mcp-config",
        "--mcp-config", '{"mcpServers":{}}', "--permission-mode", "dontAsk", "--tools", "Bash,Read,Glob,Grep",
        "--settings", str(settings_path), "--model", model, "--effort", effort,
        "--output-format", "json", "--json-schema", schema_inline,
    ]
    budget = config["providers"]["claude"].get("maxBudgetUsd")
    if budget is not None:
        argv.extend(["--max-budget-usd", str(budget)])
    return argv, None


def parse_provider_decision(provider: str, result: subprocess.CompletedProcess[str], decision_path: pathlib.Path | None) -> dict[str, Any]:
    raw: Any
    if provider == "codex":
        if decision_path is None or not decision_path.is_file():
            fail("codex did not write the structured decision")
        try:
            raw = json.loads(decision_path.read_text())
        except json.JSONDecodeError as exc:
            fail(f"codex decision is not JSON: {exc}")
    else:
        try:
            wrapper = json.loads(result.stdout)
        except json.JSONDecodeError as exc:
            fail(f"claude output is not JSON: {exc}")
        if isinstance(wrapper, dict) and isinstance(wrapper.get("structured_output"), dict):
            raw = wrapper["structured_output"]
        elif isinstance(wrapper, dict) and isinstance(wrapper.get("result"), str):
            try:
                raw = json.loads(wrapper["result"])
            except json.JSONDecodeError as exc:
                fail(f"claude result is not structured JSON: {exc}")
        else:
            raw = wrapper
    if not isinstance(raw, dict):
        fail("provider decision must be a JSON object")
    validate_decision(raw)
    return raw


def collect_probes(root: pathlib.Path, bundle: pathlib.Path, decision: dict[str, Any], destination: pathlib.Path) -> list[dict[str, Any]]:
    destination.mkdir(parents=True, exist_ok=True)
    collected: list[dict[str, Any]] = []
    for probe in decision["probes"]:
        probe_id = probe["id"]
        source = bundle / "probes" / f"{probe_id}.log"
        if not source.is_file():
            fail(f"declared probe was not executed through uw-probe: {probe_id}")
        content = source.read_text(errors="replace")
        match = re.search(r"^exit: (-?[0-9]+)$", content, re.MULTILINE)
        if not match or not re.search(rf"^## uw-cross-model-probe id={re.escape(probe_id)}$", content, re.MULTILINE):
            fail(f"invalid probe log: {probe_id}")
        target = destination / source.name
        shutil.copy2(source, target)
        collected.append({
            "id": probe_id,
            "log": relative_or_absolute(root, target),
            "sha256": sha256_file(target),
            "exit": int(match.group(1)),
            "purpose": probe["purpose"],
            "result": probe["result"],
        })
    return collected


def relative_or_absolute(root: pathlib.Path, path: pathlib.Path) -> str:
    try:
        return path.resolve().relative_to(root).as_posix()
    except ValueError:
        return str(path.resolve())


def atomic_json(path: pathlib.Path, value: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary = path.with_name(f".{path.name}.{uuid.uuid4().hex}.tmp")
    temporary.write_bytes(json_bytes(value))
    os.replace(temporary, path)


def command_doctor(args: argparse.Namespace) -> int:
    root = repo_root()
    path = config_path(root, args.config)
    config = load_json(path)
    validate_config(config)
    status = provider_status(config, args.implementer)
    status.update({"configPath": relative_or_absolute(root, path), "configHash": f"sha256:{sha256_file(path)}"})
    print(json.dumps(status, ensure_ascii=False, sort_keys=True))
    return 0


def command_run(args: argparse.Namespace) -> int:
    root = repo_root()
    path = config_path(root, args.config)
    config = load_json(path)
    validate_config(config)
    state_path = root / f".ultra-waterfall/task-{args.task}.json"
    state = load_json(state_path)
    if state.get("schemaVersion") != STATE_SCHEMA_VERSION:
        fail(f"task {args.task}: active state must use schemaVersion {STATE_SCHEMA_VERSION}")
    verifier = state.get("verifier")
    if not isinstance(verifier, dict):
        fail("loop-state verifier snapshot missing")
    required = {"mode", "implementerProvider", "provider", "configPath", "configHash", "model", "effort", "chainHead"}
    exact_keys(verifier, required, required, "loop-state verifier")
    implementer = verifier["implementerProvider"]
    status = provider_status(config, implementer)
    if verifier["mode"] != "opposite-provider" or verifier["provider"] != OPPOSITE.get(implementer):
        fail("loop-state verifier provider is not opposite to the implementer")
    expected_path = relative_or_absolute(root, path)
    if verifier["configPath"] != expected_path:
        fail("loop-state verifier config path does not match the selected config")
    expected_hash = f"sha256:{sha256_file(path)}"
    if verifier["configHash"] != expected_hash:
        fail("verifier config drifted after task start")
    if verifier["model"] != status["model"] or verifier["effort"] != status["effort"]:
        fail("loop-state verifier model/effort does not match frozen config")
    candidate = str(git(root, "rev-parse", f"{args.candidate}^{{commit}}", text=True)).strip()
    if not COMMIT_ID.fullmatch(candidate):
        fail("candidate must resolve to a commit id")
    if args.phase == "stage" and args.stage is None:
        fail("--stage is required for stage phase")
    if args.phase == "final" and args.stage is not None:
        fail("--stage is not allowed for final phase")
    milestone = str(state.get("milestone") or "m000")
    if not re.fullmatch(r"m[0-9]+", milestone):
        fail("loop-state milestone must use m<digits>")
    prefix = f"task_{milestone}_{args.task}"
    if args.phase == "stage":
        frozen_log = root / "mydocs/working" / f"{prefix}_stage{args.stage}_{candidate[:12]}.log"
        phase_name = f"stage{args.stage}"
    else:
        frozen_log = root / "mydocs/working" / f"{prefix}_final_{candidate[:12]}.log"
        phase_name = "final"
    frozen_exits = re.findall(r"^exit: ([0-9]+)$", frozen_log.read_text(errors="replace"), re.MULTILINE) if frozen_log.is_file() else []
    if not frozen_exits or any(code != "0" for code in frozen_exits):
        fail(f"frozen verification log missing or nonzero: {relative_or_absolute(root, frozen_log)}")
    previous, ledger = load_chain(root, verifier["chainHead"])
    timeout = config["timeoutSeconds"]
    errors: list[str] = []
    for attempt in (1, 2):
        run_id = str(uuid.uuid4())
        started = utc_now()
        try:
            with tempfile.TemporaryDirectory(prefix=f"uw-verifier-task{args.task}-") as tmp:
                bundle = pathlib.Path(tmp)
                bundle_hash = build_bundle(root, args.task, args.phase, args.stage, candidate, state, config, frozen_log, ledger, bundle)
                prompt = (bundle / "prompt.md").read_text() + "\n\nRead input.json and begin the independent verification.\n"
                argv, decision_path = provider_argv(status["provider"], status, config, bundle)
                result = run_checked(argv, cwd=bundle, timeout=timeout, stdin=prompt)
                (bundle / "provider.stdout.log").write_text(result.stdout)
                (bundle / "provider.stderr.log").write_text(result.stderr)
                if result.returncode != 0:
                    diagnostic = "\n".join(part for part in (result.stderr.strip(), result.stdout.strip()) if part)
                    fail(f"{status['provider']} exited {result.returncode}: {diagnostic[-1000:]}")
                decision = parse_provider_decision(status["provider"], result, decision_path)
                artifact_root = root / "mydocs/working" / f"{prefix}_{phase_name}_{candidate[:12]}_{run_id[:8]}.probes"
                probes = collect_probes(root, bundle, decision, artifact_root)
                completed = utc_now()
                envelope_path = root / "mydocs/working" / f"{prefix}_{phase_name}_{candidate[:12]}_{run_id[:8]}.verifier.json"
                charter_rel = str(safe_relative(validate_nonempty(state.get("charter"), "loop-state charter"), "loop-state charter"))
                charter_bytes = git(root, "show", f"{candidate}:{charter_rel}", text=False)
                assert isinstance(charter_bytes, bytes)
                envelope = {
                    "schemaVersion": SCHEMA_VERSION,
                    "task": args.task,
                    "phase": args.phase,
                    "stage": args.stage,
                    "candidate": candidate,
                    "charter": {"path": charter_rel, "sha256": sha256_bytes(charter_bytes)},
                    "config": {"path": relative_or_absolute(root, path), "sha256": sha256_file(path)},
                    "implementer": {"provider": implementer},
                    "verifier": {
                        "provider": status["provider"],
                        "binary": status["binary"],
                        "requestedModel": status["model"],
                        "requestedEffort": status["effort"],
                        "cliVersion": status["cliVersion"],
                    },
                    "invocation": {
                        "runId": run_id,
                        "startedAt": started,
                        "completedAt": completed,
                        "fresh": True,
                        "persistedSession": False,
                        "bundleSha256": bundle_hash,
                        "attempt": attempt,
                    },
                    "previousEnvelope": previous,
                    "frozenVerification": {
                        "log": relative_or_absolute(root, frozen_log),
                        "sha256": sha256_file(frozen_log),
                        "exit": 0,
                    },
                    "probes": probes,
                    "decision": decision,
                    "status": decision["verdict"],
                }
                atomic_json(envelope_path, envelope)
                envelope_ref = {"path": relative_or_absolute(root, envelope_path), "sha256": sha256_file(envelope_path)}
                print(json.dumps({"status": envelope["status"], "envelope": envelope_ref, "provider": status["provider"], "model": status["model"], "attempt": attempt}, ensure_ascii=False, sort_keys=True))
                return 0 if envelope["status"] == "OK" else 1
        except VerifierError as exc:
            errors.append(f"attempt {attempt}: {exc}")
    fail("; ".join(errors))
    return 2


def parser() -> argparse.ArgumentParser:
    root = argparse.ArgumentParser(prog="uw-verifier", description="Ultra-Waterfall fresh cross-model verifier")
    sub = root.add_subparsers(dest="command", required=True)
    doctor = sub.add_parser("doctor", help="validate config, binary, auth, and opposite-provider selection")
    doctor.add_argument("--implementer", choices=sorted(PROVIDERS), required=True)
    doctor.add_argument("--config")
    doctor.set_defaults(func=command_doctor)
    run = sub.add_parser("run", help="run a fresh external verification and write an atomic envelope")
    run.add_argument("--task", type=int, required=True)
    run.add_argument("--phase", choices=["stage", "final"], required=True)
    run.add_argument("--stage", type=int)
    run.add_argument("--candidate", required=True)
    run.add_argument("--config")
    run.set_defaults(func=command_run)
    return root


if __name__ == "__main__":
    # Parse once here; keeping main explicit makes the script easy to exercise with fake CLIs.
    try:
        arguments = parser().parse_args()
        raise SystemExit(arguments.func(arguments))
    except VerifierError as error:
        print(f"uw-verifier: FAIL: {error}", file=sys.stderr)
        raise SystemExit(2)

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Y-Park/ultra-waterfall/schemas/verifier-envelope-0.1.0.json",
  "title": "Ultra-Waterfall cross-model verification envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "task", "phase", "stage", "candidate", "charter",
    "config", "implementer", "verifier", "invocation", "previousEnvelope",
    "frozenVerification", "probes", "decision", "status"
  ],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "task": { "type": "integer", "minimum": 1 },
    "phase": { "enum": ["stage", "final"] },
    "stage": { "type": ["integer", "null"], "minimum": 1 },
    "candidate": { "type": "string", "pattern": "^[0-9a-f]{40,64}$" },
    "charter": { "$ref": "#/$defs/pathHash" },
    "config": { "$ref": "#/$defs/pathHash" },
    "implementer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider"],
      "properties": { "provider": { "enum": ["codex", "claude"] } }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "binary", "requestedModel", "requestedEffort", "cliVersion"],
      "properties": {
        "provider": { "enum": ["codex", "claude"] },
        "binary": { "type": "string", "minLength": 1 },
        "requestedModel": { "type": "string", "minLength": 1 },
        "requestedEffort": { "type": "string", "minLength": 1 },
        "cliVersion": { "type": "string", "minLength": 1 }
      }
    },
    "invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runId", "startedAt", "completedAt", "fresh", "persistedSession", "bundleSha256", "attempt"],
      "properties": {
        "runId": { "type": "string", "format": "uuid" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "fresh": { "const": true },
        "persistedSession": { "const": false },
        "bundleSha256": { "$ref": "#/$defs/sha256" },
        "attempt": { "type": "integer", "minimum": 1, "maximum": 2 }
      }
    },
    "previousEnvelope": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/pathHash" }
      ]
    },
    "frozenVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["log", "sha256", "exit"],
      "properties": {
        "log": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "exit": { "const": 0 }
      }
    },
    "probes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "log", "sha256", "exit", "purpose", "result"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
          "log": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/sha256" },
          "exit": { "type": "integer" },
          "purpose": { "type": "string", "minLength": 1 },
          "result": { "enum": ["no-violation", "violation", "inconclusive"] }
        }
      }
    },
    "decision": { "$ref": "./decision.schema.json" },
    "status": { "enum": ["OK", "MISS"] }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "pathHash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}

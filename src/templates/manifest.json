    { "source": "src/templates/.claude/settings.json", "target": ".claude/settings.json", "kind": "file", "role": "enforcement-claude-friction", "updatePolicy": "merge", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },

    { "source": "src/templates/mydocs/orders/README.md", "target": "mydocs/orders/README.md", "kind": "file", "role": "artifact-folder-guide", "updatePolicy": "overwrite", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },

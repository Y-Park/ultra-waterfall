{
  "schemaVersion": "0.1.0",
  "framework": "ultra-waterfall",
  "frameworkVersion": "0.3.0",
  "distribution": {
    "canonicalSource": "github-repo",
    "version": "0.3.0",
    "status": "published",
    "note": "ultra-waterfall은 md 문서 묶음이라 릴리스 아티팩트(tag/tarball/checksum 핀)를 두지 않는다. 적용은 이 저장소(main)에서 src/templates를 직접 복사한다."
  },
  "applicationMode": "adoption-only",
  "strictManifest": true,
  "forbiddenTargetsOnAdoption": [
    "docs/**",
    "src/**",
    "examples/**",
    "schemas/**",
    "package.json",
    "tsconfig.json"
  ],
  "outOfScopeArtifactPolicy": "During adoption, record project-specific code, docs, architecture, roadmap, API contracts, examples, and schemas as deferred task candidates instead of creating or modifying files.",
  "versionState": {
    "targetPath": ".ultra-waterfall/version.json",
    "format": {
      "schemaVersion": "0.1.0",
      "frameworkVersion": "0.3.0",
      "source": "github-repo",
      "sourceRef": "main (또는 적용 시점 commit SHA)",
      "installedAt": "ISO-8601 timestamp",
      "updatedAt": "ISO-8601 timestamp"
    },
    "updatePolicy": "preserve"
  },
  "updatePolicies": {
    "overwrite": {
      "description": "Update by re-copying from the repo; since checksums are not pinned, treat any existing target as a potential local modification and report it as a conflict (review the git diff) before replacing.",
      "requiresReviewOnConflict": true
    },
    "merge": {
      "description": "Create a patch and require review before replacing user-visible or commonly customized files.",
      "requiresReviewOnConflict": true
    },
    "manual": {
      "description": "Do not update automatically; show the migration guide and require explicit maintainer action.",
      "requiresReviewOnConflict": true
    },
    "preserve": {
      "description": "Create when missing, then keep existing target content unless an explicit change is approved.",
      "requiresReviewOnConflict": true
    },
    "symlink": {
      "description": "Ensure the target is a symlink to the expected path; prompt before replacing an existing file or directory.",
      "requiresReviewOnConflict": true
    }
  },
  "checksum": {
    "algorithm": "sha256",
    "status": "unversioned",
    "value": null,
    "note": "체크섬을 핀하지 않는다(릴리스 아티팩트 없음). 무결성·업데이트 충돌은 git diff 검토로 다룬다."
  },
  "files": [
    { "source": "src/templates/AGENTS1.md", "target": "AGENTS.md", "kind": "file", "role": "agent-runtime-rules", "updatePolicy": "merge", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },
    { "source": "src/templates/CLAUDE1.md", "target": "CLAUDE.md", "kind": "file", "role": "claude-entrypoint", "updatePolicy": "merge", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },
    { "source": "src/templates/.github/ISSUE_TEMPLATE/task.yml", "target": ".github/ISSUE_TEMPLATE/task.yml", "kind": "file", "role": "github-issue-form", "updatePolicy": "merge", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },
    { "source": "src/templates/.github/pull_request_template.md", "target": ".github/pull_request_template.md", "kind": "file", "role": "github-pr-template", "updatePolicy": "merge", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },
    { "source": "src/templates/.ultra-waterfall/bin/uw-gate", "target": ".ultra-waterfall/bin/uw-gate", "kind": "file", "role": "enforcement-cli", "updatePolicy": "overwrite", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },
    { "source": "src/templates/.ultra-waterfall/gate/check-gates.sh", "target": ".ultra-waterfall/gate/check-gates.sh", "kind": "file", "role": "enforcement-ci-authoritative", "updatePolicy": "overwrite", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },
    { "source": "src/templates/.ultra-waterfall/hooks/pre-commit", "target": ".ultra-waterfall/hooks/pre-commit", "kind": "file", "role": "enforcement-git-hook", "updatePolicy": "overwrite", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },
    { "source": "src/templates/.ultra-waterfall/hooks/pre-push", "target": ".ultra-waterfall/hooks/pre-push", "kind": "file", "role": "enforcement-git-hook", "updatePolicy": "overwrite", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },
    { "source": "src/templates/.ultra-waterfall/hooks/claude-guard.sh", "target": ".ultra-waterfall/hooks/claude-guard.sh", "kind": "file", "role": "enforcement-claude-pretooluse", "updatePolicy": "overwrite", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },

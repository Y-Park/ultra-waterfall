    { "source": "src/templates/mydocs/tech/README.md", "target": "mydocs/tech/README.md", "kind": "file", "role": "artifact-folder-guide", "updatePolicy": "overwrite", "checksum": { "algorithm": "sha256", "status": "unversioned", "value": null } },

    "overwrite": {
      "description": "Replace when the target still matches the previous framework checksum; treat local modifications as conflicts.",
      "requiresReviewOnConflict": true
    },
    "merge": {
      "description": "Create a patch and require review before replacing user-visible or commonly customized files.",
      "requiresReviewOnConflict": true
    },
    "manual": {
      "description": "Do not update automatically; show the migration guide and require explicit maintainer action.",
      "requiresReviewOnConflict": true
    },
    "preserve": {
      "description": "Create when missing, then keep existing target content unless an explicit change is approved.",
      "requiresReviewOnConflict": true
    },
    "symlink": {
      "description": "Ensure the target is a symlink to the expected path; prompt before replacing an existing file or directory.",
      "requiresReviewOnConflict": true
    }
  },
